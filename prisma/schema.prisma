generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model rol {
  id          Int     @id @default(autoincrement())
  description String  @db.VarChar(200)
  status      Boolean
  user        user[]
}

model task {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(150)
  description String   @db.VarChar(250)
  priority    Boolean
  created_at  DateTime @default(now())
  user_id     Int
  user        user     @relation(fields: [user_id], references: [id], map: "Task_user_id_fkey")

  @@index([user_id], map: "Task_user_id_fkey")
}

model user {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(200)
  lastName     String   @db.VarChar(250)
  userName     String   @db.VarChar(100)
  password     String
  created_at   DateTime @default(now())
  role_id      Int?
  refreshToken String?  @db.Text
  hash         String?  @db.VarChar(255)
  task         task[]
  rol          rol?     @relation(fields: [role_id], references: [id], map: "User_role_id_fkey")
 logs Logs[] @relation("UserLogs")
  @@index([role_id], map: "User_role_id_fkey")
}

model Logs {
  id Int @id @default(autoincrement())
  statusCode Int
  timestamp DateTime
  path String @db.MediumText
  error String @db.MediumText
  errorCode String @db.MediumText
  session_id Int?

  user user? @relation("UserLogs", fields: [session_id], references: [id])
}